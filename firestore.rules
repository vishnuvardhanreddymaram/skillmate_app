rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles – allow any authenticated user to read, owners can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Swap requests – any authenticated user can create/read their requests
    match /requests/{requestId} {
      allow read, write: if request.auth != null;
    }
    // Chats & messages – authenticated users only
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    // AI messages – per‑user
    match /users/{userId}/ai_messages/{msgId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
